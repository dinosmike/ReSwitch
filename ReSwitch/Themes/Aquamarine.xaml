<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
                    xmlns:net="clr-namespace:System;assembly=System.Runtime">
    <!-- Тема «Аквамарин»: сине-голубые оттенки (не бирюза). -->
    <Color x:Key="Rs.Color.Background">#0B1428</Color>
    <Color x:Key="Rs.Color.Surface">#0F1E3D</Color>
    <Color x:Key="Rs.Color.Border">#3D5A8C</Color>
    <Color x:Key="Rs.Color.TextPrimary">#E8F2FF</Color>
    <Color x:Key="Rs.Color.TextMuted">#8CAED9</Color>
    <Color x:Key="Rs.Color.Accent">#5EB3FF</Color>
    <Color x:Key="Rs.Color.AccentDim">#2563EB</Color>
    <!-- Иконки «Получить» / «Применить»: цвет и размер (Segoe MDL2 Assets) -->
    <Color x:Key="Rs.Color.ProfileActionIcon">#93C5FD</Color>
    <SolidColorBrush x:Key="Rs.ProfileAction.IconBrush" Color="{StaticResource Rs.Color.ProfileActionIcon}"/>
    <net:Double x:Key="Rs.ProfileAction.IconSize">12</net:Double>

    <SolidColorBrush x:Key="Rs.Window.Background" Color="{StaticResource Rs.Color.Background}"/>
    <SolidColorBrush x:Key="Rs.Surface" Color="{StaticResource Rs.Color.Surface}"/>
    <SolidColorBrush x:Key="Rs.Border" Color="{StaticResource Rs.Color.Border}"/>
    <SolidColorBrush x:Key="Rs.Text.Primary" Color="{StaticResource Rs.Color.TextPrimary}"/>
    <SolidColorBrush x:Key="Rs.Text.Muted" Color="{StaticResource Rs.Color.TextMuted}"/>
    <SolidColorBrush x:Key="Rs.Accent" Color="{StaticResource Rs.Color.Accent}"/>
    <SolidColorBrush x:Key="Rs.Accent.Dim" Color="{StaticResource Rs.Color.AccentDim}"/>
    <SolidColorBrush x:Key="Rs.SaveSuccess" Color="#4ADE80"/>
    <SolidColorBrush x:Key="Rs.Button.Accent.Background" Color="#0f295f"/>
    <SolidColorBrush x:Key="Rs.Button.PressedBackground" Color="#0F2850"/>
    <SolidColorBrush x:Key="Rs.TitleBar.ButtonHoverBackground" Color="#1A2F55"/>
    <SolidColorBrush x:Key="Rs.TitleBar.ButtonPressedBackground" Color="#243A66"/>
    <SolidColorBrush x:Key="Rs.TitleBar.CloseHoverBackground" Color="#E81123"/>
    <SolidColorBrush x:Key="Rs.TitleBar.ClosePressedBackground" Color="#C50F1F"/>
    <SolidColorBrush x:Key="Rs.TitleBar.CloseHoverForeground" Color="#FFFFFF"/>

    <!-- Выпадающие списки и Popup используют SystemColors -->
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.WindowBrushKey}" Color="{StaticResource Rs.Color.Surface}"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.WindowTextBrushKey}" Color="{StaticResource Rs.Color.TextPrimary}"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightBrushKey}" Color="#FF1E3A5F"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightTextBrushKey}" Color="{StaticResource Rs.Color.TextPrimary}"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlBrushKey}" Color="{StaticResource Rs.Color.Surface}"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlDarkBrushKey}" Color="{StaticResource Rs.Color.Border}"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.InfoBrushKey}" Color="{StaticResource Rs.Color.Surface}"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.InfoTextBrushKey}" Color="{StaticResource Rs.Color.TextPrimary}"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Rs.Window.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Rs.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Rs.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Muted}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Rs.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Rs.Border}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Rs.Accent}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <!-- Поле «Название» профиля на главном окне: измените FontSize здесь -->
    <Style x:Key="Rs.TextBox.ProfileName" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontSize" Value="20"/>
    </Style>

    <Style x:Key="Rs.TextBlock.ProfileActionIcon" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="{DynamicResource Rs.ProfileAction.IconSize}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.ProfileAction.IconBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Grid Width="18" Height="18" VerticalAlignment="Top">
                            <Border x:Name="CheckMarkBorder"
                                    CornerRadius="3"
                                    Background="{DynamicResource Rs.Surface}"
                                    BorderBrush="{DynamicResource Rs.Border}"
                                    BorderThickness="1"/>
                            <TextBlock x:Name="CheckGlyph"
                                       Text="✓"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource Rs.Accent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="CheckMarkBorder" Property="Background" Value="#1A3055"/>
                            <Setter TargetName="CheckMarkBorder" Property="BorderBrush" Value="{DynamicResource Rs.Accent.Dim}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckMarkBorder" Property="BorderBrush" Value="{DynamicResource Rs.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Rs.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Rs.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Slide">
                            <Border BorderThickness="1"
                                    Background="{DynamicResource Rs.Surface}"
                                    BorderBrush="{DynamicResource Rs.Border}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{Binding ActualWidth, ElementName=templateRoot}">
                                <ScrollViewer>
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                        <ToggleButton x:Name="ToggleButton"
                                      Focusable="False"
                                      ClickMode="Press"
                                      OverridesDefaultStyle="True"
                                      FocusVisualStyle="{x:Null}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="{DynamicResource Rs.Surface}"
                                      BorderBrush="{DynamicResource Rs.Border}"
                                      BorderThickness="1">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="ToggleBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="1"
                                                    Background="Transparent"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1,0,0,0">
                                                <Path Data="M0,0 L4,4 L8,0 Z"
                                                      Fill="{DynamicResource Rs.Text.Primary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Stretch="None"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource Rs.TitleBar.ButtonHoverBackground}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource Rs.TitleBar.ButtonPressedBackground}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource Rs.TitleBar.ButtonPressedBackground}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Margin="8,0,28,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource Rs.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2D4A75"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Карточки секций в окне настроек -->
    <Style x:Key="Rs.Settings.Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Rs.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Rs.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="Rs.Settings.SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Muted}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="Rs.Button" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Rs.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Rs.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Rs.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Rs.Button.PressedBackground}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Rs.Button.Accent" TargetType="Button" BasedOn="{StaticResource Rs.Button}">
        <Setter Property="Background" Value="{DynamicResource Rs.Button.Accent.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Rs.Accent.Dim}"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Accent}"/>
    </Style>

    <!-- Кнопки кастомного заголовка окна -->
    <Style x:Key="Rs.TitleBar.Button" TargetType="Button">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Rs.TitleBar.ButtonHoverBackground}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Rs.TitleBar.ButtonPressedBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Rs.TitleBar.Close" TargetType="Button" BasedOn="{StaticResource Rs.TitleBar.Button}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Rs.TitleBar.CloseHoverBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Rs.TitleBar.CloseHoverForeground}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Rs.TitleBar.ClosePressedBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Rs.TitleBar.CloseHoverForeground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
