<Window x:Class="ReSwitch.AdviceOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        ShowActivated="False">
    <!-- #01000000: минимальная альфа, чтобы у layered-окна вся габаритная область участвовала в hit-test (иначе «просвечивает» к рабочему столу). -->
    <Border x:Name="RootBorder"
            Background="#01000000"
            Padding="12,10,44,44">
        <TextBlock x:Name="TipText"
                   TextWrapping="NoWrap"
                   SnapsToDevicePixels="True">
            <TextBlock.Effect>
                <!-- ShadowDepth=0: тень без смещения, размытие вокруг букв. -->
                <DropShadowEffect BlurRadius="26"
                                  ShadowDepth="0"
                                  Color="Black"
                                  Opacity="0.72"/>
            </TextBlock.Effect>
        </TextBlock>
    </Border>
</Window>
