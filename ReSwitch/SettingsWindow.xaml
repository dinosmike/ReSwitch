<Window x:Class="ReSwitch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource Loc_SettingsWindow_Title}"
        Width="520"
        MinHeight="400"
        MinWidth="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent">
    <Window.Resources>
        <!-- Компактный радиопереключатель: круг сразу слева от подписи (без раздвижки при Stretch). -->
        <Style x:Key="ThemeRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Primary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="16" Height="16">
                                    <Ellipse x:Name="BulletOuter"
                                             Stroke="{DynamicResource Rs.Border}"
                                             StrokeThickness="1"
                                             Fill="Transparent"/>
                                    <Ellipse x:Name="BulletInner"
                                             Width="8" Height="8"
                                             Fill="{DynamicResource Rs.Accent}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed"/>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="5,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BulletInner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="BulletOuter" Property="Stroke" Value="{DynamicResource Rs.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <!--
      Высота окна: SizeToContent=Height (по контенту, без полосы прокрутки).
      Ширина фиксирована (Width). ResizeMode=NoResize — без ручного растягивания.
    -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource Rs.Window.Background}"
            BorderBrush="{DynamicResource Rs.Border}"
            BorderThickness="1">
        <DockPanel>
            <!-- Заголовок -->
            <Border DockPanel.Dock="Top"
                    Height="44"
                    Background="{DynamicResource Rs.Surface}"
                    BorderBrush="{DynamicResource Rs.Border}"
                    BorderThickness="0,0,0,1"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="Transparent"
                            Padding="14,0,8,0"
                            MouseLeftButtonDown="TitleBar_OnMouseDown">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Loc_SettingsWindow_Header}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Rs.Text.Primary}"/>
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource Rs.Text.Muted}"
                                       Text="{DynamicResource Loc_SettingsWindow_Subtitle}"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="1"
                            Style="{StaticResource Rs.TitleBar.Close}"
                            Content="&#x00D7;"
                            ToolTip="{DynamicResource Loc_SettingsWindow_CloseWithoutSave}"
                            Click="TitleBarClose_OnClick"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <Grid Margin="16,12,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                        <!-- Язык: подпись и список в одну линию -->
                        <Border Style="{StaticResource Rs.Settings.Card}">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0"
                                       Content="{DynamicResource Loc_SettingsWindow_LanguageLabel}"
                                       Target="{Binding ElementName=LanguageCombo}"
                                       VerticalAlignment="Center"/>
                                <ComboBox x:Name="LanguageCombo"
                                          Grid.Column="2"
                                          MinWidth="0"
                                          VerticalAlignment="Center"
                                          DisplayMemberPath="NativeName"
                                          SelectedValuePath="Code"
                                          SelectionChanged="LanguageCombo_OnSelectionChanged"/>
                            </Grid>
                        </Border>

                        <!-- Запуск и окно -->
                        <Border Style="{StaticResource Rs.Settings.Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Rs.Settings.SectionTitle}" Text="{DynamicResource Loc_SettingsWindow_SectionStartup}"/>
                                <CheckBox x:Name="AutostartCheck"
                                          Margin="0,0,0,4"
                                          Content="{DynamicResource Loc_SettingsWindow_Autostart}"/>
                                <CheckBox x:Name="StartupToTrayCheck"
                                          Margin="0,4">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="{DynamicResource Loc_SettingsWindow_StartupToTray}"/>
                                </CheckBox>
                                <CheckBox x:Name="TrayHideAnimationCheck"
                                          Margin="0,4">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="{DynamicResource Loc_SettingsWindow_TrayAnimation}"/>
                                </CheckBox>
                                <CheckBox x:Name="CloseToTrayCheck"
                                          Margin="0,4">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="{DynamicResource Loc_SettingsWindow_CloseToTrayCross}"/>
                                </CheckBox>

                            </StackPanel>
                        </Border>

                        <!-- Совет (подписи только на русском) — Margin у карточки из Rs.Settings.Card (0,0,0,12) -->
                        <Border Style="{StaticResource Rs.Settings.Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Rs.Settings.SectionTitle}">
                                    <Hyperlink NavigateUri="https://fucking-great-advice.ru/"
                                               RequestNavigate="AdviceSectionHyperlink_OnRequestNavigate"
                                               TextDecorations="{x:Null}"
                                               Foreground="{DynamicResource Rs.Text.Muted}"
                                               Cursor="Arrow">
                                        ОХУЕННЫЙ БЛЯТЬ СОВЕТ
                                    </Hyperlink>
                                </TextBlock>
                                <CheckBox x:Name="AdviceOnStartupCheck"
                                          Margin="0,0,0,8"
                                          Content="{DynamicResource Loc_SettingsWindow_AdviceOnStartup}"/>
                            </StackPanel>
                        </Border>

                        <!-- Тема -->
                        <Border Style="{StaticResource Rs.Settings.Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Rs.Settings.SectionTitle}" Text="{DynamicResource Loc_SettingsWindow_SectionTheme}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="ThemeDarkRadio"
                                                 Grid.Column="0"
                                                 Style="{StaticResource ThemeRadioStyle}"
                                                 GroupName="UiTheme"
                                                 Content="{DynamicResource Loc_SettingsWindow_ThemeDark}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Checked="ThemeRadio_OnChecked"/>
                                    <RadioButton x:Name="ThemeLightRadio"
                                                 Grid.Column="1"
                                                 Style="{StaticResource ThemeRadioStyle}"
                                                 GroupName="UiTheme"
                                                 Content="{DynamicResource Loc_SettingsWindow_ThemeLight}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Checked="ThemeRadio_OnChecked"/>
                                    <RadioButton x:Name="ThemeFuchsiaRadio"
                                                 Grid.Column="2"
                                                 Style="{StaticResource ThemeRadioStyle}"
                                                 GroupName="UiTheme"
                                                 Content="{DynamicResource Loc_SettingsWindow_ThemeFuchsia}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Checked="ThemeRadio_OnChecked"/>
                                    <RadioButton x:Name="ThemeAquamarineRadio"
                                                 Grid.Column="3"
                                                 Style="{StaticResource ThemeRadioStyle}"
                                                 GroupName="UiTheme"
                                                 Content="{DynamicResource Loc_SettingsWindow_ThemeAquamarine}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Checked="ThemeRadio_OnChecked"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Смена режима дисплея -->
                        <Border Style="{StaticResource Rs.Settings.Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Rs.Settings.SectionTitle}" Text="{DynamicResource Loc_SettingsWindow_SectionResolution}"/>
                                <CheckBox x:Name="ConfirmCheck"
                                          Margin="0,0,0,2"
                                          Content="{DynamicResource Loc_SettingsWindow_ConfirmResolution}"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="88"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TimeoutLabel"
                                               Grid.Row="0" Grid.Column="0"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Rs.Text.Muted}"
                                               Text="{DynamicResource Loc_SettingsWindow_TimeoutLabel}"/>
                                    <TextBox x:Name="TimeoutBox"
                                             Grid.Row="0" Grid.Column="1"
                                             VerticalAlignment="Center"
                                             MaxLength="3"
                                             HorizontalContentAlignment="Center"
                                             ToolTip="{DynamicResource Loc_SettingsWindow_TimeoutTooltip}"/>

                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Трей -->
                        <Border Style="{StaticResource Rs.Settings.Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Rs.Settings.SectionTitle}" Text="{DynamicResource Loc_SettingsWindow_SectionTray}"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="{DynamicResource Rs.Text.Muted}"
                                           Margin="0,0,0,12"
                                           Text="{DynamicResource Loc_SettingsWindow_TrayHint}"/>
                                <Label Content="{DynamicResource Loc_SettingsWindow_TraySingleClickLabel}"/>
                                <StackPanel Margin="0,4,0,0">
                                    <RadioButton x:Name="TraySingleOpenWindow"
                                                 Style="{StaticResource ThemeRadioStyle}"
                                                 GroupName="TraySingle"
                                                 Content="{DynamicResource Loc_SettingsWindow_TrayOpenWindow}"
                                                 Margin="0,0,0,8"/>
                                    <RadioButton x:Name="TraySingleToggleProfile"
                                                 Style="{StaticResource ThemeRadioStyle}"
                                                 GroupName="TraySingle"
                                                 Content="{DynamicResource Loc_SettingsWindow_TrayToggleProfile}"/>
                                </StackPanel>
                                <CheckBox x:Name="TrayShowResolutionMenuCheck"
                                          Margin="0,12,0,0"
                                          Content="{DynamicResource Loc_SettingsWindow_TrayShowResolutionMenu}"
                                          Checked="TrayShowResolutionMenuCheck_OnChecked"
                                          Unchecked="TrayShowResolutionMenuCheck_OnChecked"/>
                                <CheckBox x:Name="TrayShowProfileNamesCheck"
                                          Margin="0,8,0,0"
                                          Content="{DynamicResource Loc_SettingsWindow_TrayShowProfileNames}"/>
                            </StackPanel>
                        </Border>
                </StackPanel>

                <!-- Нижняя панель (верхний отступ 0 — расстояние до последней карточки задаёт Margin карточки 12, как между блоками) -->
                <Border Grid.Row="1"
                        Margin="0,0,0,16"
                        Padding="0,16,0,0"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource Rs.Border}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Rs.Button}"
                                MinWidth="108"
                                Margin="0,0,10,0"
                                Padding="12,8"
                                Click="Cancel_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE711;"/>
                                <TextBlock VerticalAlignment="Center"
                                           Text="{DynamicResource Loc_SettingsWindow_Cancel}"
                                           Foreground="{DynamicResource Rs.Text.Primary}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Rs.Button.Accent}"
                                MinWidth="120"
                                Padding="12,8"
                                IsDefault="True"
                                Click="Save_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE74E;"/>
                                <TextBlock VerticalAlignment="Center"
                                           Text="{DynamicResource Loc_SettingsWindow_Save}"
                                           Foreground="{DynamicResource Rs.Accent}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
