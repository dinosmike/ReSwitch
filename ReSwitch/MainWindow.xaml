<Window x:Class="ReSwitch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="{DynamicResource Loc_Common_AppTitle}"
        Height="520" Width="620"
        MinHeight="520" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        RenderTransformOrigin="0.5,0.5">
    <Window.Resources>
        <!-- Задержка появления подсказок (мс). Меняйте здесь — то же значение подхватят окна настроек и подтверждения. -->
        <sys:Int32 x:Key="Rs.Tooltip.InitialShowDelayMs">100</sys:Int32>
    </Window.Resources>
    <Window.RenderTransform>
        <ScaleTransform x:Name="TrayHideScale" ScaleX="1" ScaleY="1"/>
    </Window.RenderTransform>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource Rs.Window.Background}"
            BorderBrush="{DynamicResource Rs.Border}"
            BorderThickness="1">
        <DockPanel>
            <!-- Заголовок: перетаскивание слева, три кнопки справа -->
            <Border DockPanel.Dock="Top"
                    Height="44"
                    Background="{DynamicResource Rs.Surface}"
                    BorderBrush="{DynamicResource Rs.Border}"
                    BorderThickness="0,0,0,1"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="Transparent"
                            Padding="14,0,8,0"
                            MouseLeftButtonDown="TitleBar_OnMouseDown">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ReSwitch" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource Rs.Text.Muted}"
                                       Text="{DynamicResource Loc_MainWindow_Subtitle}"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnMinimizeToTray"
                                Click="TitleBarMinimizeToTray_OnClick"
                                ToolTip="{DynamicResource Loc_MainWindow_TooltipMinimizeToTray}"
                                Style="{StaticResource Rs.TitleBar.Button}"
                                Content="&#x2B07;"/>
                        <Button x:Name="BtnMinimize"
                                Click="TitleBarMinimize_OnClick"
                                ToolTip="{DynamicResource Loc_MainWindow_TooltipMinimize}"
                                Style="{StaticResource Rs.TitleBar.Button}"
                                Content="&#x2212;"/>
                        <Button x:Name="BtnClose"
                                Click="TitleBarClose_OnClick"
                                Style="{StaticResource Rs.TitleBar.Close}"
                                Content="&#x00D7;"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DockPanel Margin="24">
                <Border DockPanel.Dock="Top" Margin="0,0,0,16" Padding="0,0,0,16" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Rs.Border}">
                    <TextBlock Foreground="{DynamicResource Rs.Text.Muted}" TextWrapping="Wrap"
                               Text="{DynamicResource Loc_MainWindow_Intro}"/>
                </Border>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <!-- Место под галочку фиксировано (MinWidth), чтобы кнопка не сдвигалась -->
                    <TextBlock x:Name="SaveFeedbackCheck"
                               Text="✓"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Rs.SaveSuccess}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               MinWidth="28"
                               TextAlignment="Center"
                               Opacity="0"/>
                    <Button x:Name="BtnSaveProfiles"
                            Content="{DynamicResource Loc_MainWindow_SaveProfiles}"
                            MinWidth="160"
                            Margin="0,0,12,0"
                            Padding="16,8"
                            Style="{StaticResource Rs.Button.Accent}"
                            Click="Save_OnClick"/>
                    <Button Style="{StaticResource Rs.Button}" MinWidth="120" Padding="12,8" Click="OpenSettings_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" FontSize="12" Text="&#xE713;"/>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{DynamicResource Loc_MainWindow_Settings}"
                                       Foreground="{DynamicResource Rs.Text.Primary}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource Rs.Surface}" BorderBrush="{DynamicResource Rs.Border}" BorderThickness="1" CornerRadius="10" Padding="18">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="15" Text="{DynamicResource Loc_MainWindow_Profile1Header}"/>
                            <Label Content="{DynamicResource Loc_MainWindow_LabelName}"/>
                            <TextBox x:Name="P0Name" Style="{StaticResource Rs.TextBox.ProfileName}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelWidth}"/>
                                    <TextBox x:Name="P0W"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelHeight}"/>
                                    <TextBox x:Name="P0H"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelHz}"/>
                                    <TextBox x:Name="P0Hz"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelBpp}"/>
                                    <TextBox x:Name="P0Bpp"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Style="{StaticResource Rs.Button}"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        ToolTip="{DynamicResource Loc_MainWindow_TooltipGetFromWindows}"
                                        Click="P0_FromWindows_OnClick">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE896;"/>
                                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource Loc_MainWindow_ButtonGet}" Foreground="{DynamicResource Rs.Text.Primary}"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2"
                                        Style="{StaticResource Rs.Button.Accent}"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        ToolTip="{DynamicResource Loc_MainWindow_TooltipApplyProfile}"
                                        Click="P0_Apply_OnClick">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE73E;"/>
                                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource Loc_MainWindow_ButtonApply}" Foreground="{DynamicResource Rs.Accent}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{DynamicResource Rs.Surface}" BorderBrush="{DynamicResource Rs.Border}" BorderThickness="1" CornerRadius="10" Padding="18">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="15" Text="{DynamicResource Loc_MainWindow_Profile2Header}"/>
                            <Label Content="{DynamicResource Loc_MainWindow_LabelName}"/>
                            <TextBox x:Name="P1Name" Style="{StaticResource Rs.TextBox.ProfileName}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelWidth}"/>
                                    <TextBox x:Name="P1W"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelHeight}"/>
                                    <TextBox x:Name="P1H"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelHz}"/>
                                    <TextBox x:Name="P1Hz"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="{DynamicResource Loc_MainWindow_LabelBpp}"/>
                                    <TextBox x:Name="P1Bpp"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Style="{StaticResource Rs.Button}"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        ToolTip="{DynamicResource Loc_MainWindow_TooltipGetFromWindows}"
                                        Click="P1_FromWindows_OnClick">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE896;"/>
                                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource Loc_MainWindow_ButtonGet}" Foreground="{DynamicResource Rs.Text.Primary}"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2"
                                        Style="{StaticResource Rs.Button.Accent}"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        ToolTip="{DynamicResource Loc_MainWindow_TooltipApplyProfile}"
                                        Click="P1_Apply_OnClick">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE73E;"/>
                                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource Loc_MainWindow_ButtonApply}" Foreground="{DynamicResource Rs.Accent}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </DockPanel>
    </Border>
</Window>
