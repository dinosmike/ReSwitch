<UserControl x:Class="ReSwitch.ProfileCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="284" MinWidth="284" MaxWidth="284">
    <UserControl.Resources>
        <!-- Круглая кнопка «×» как у плюса на главном окне; красная заливка только при наведении -->
        <Style x:Key="Rs.Profile.RemoveRound" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Rs.Text.Muted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="11"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Rs.TitleBar.CloseHoverBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Rs.TitleBar.CloseHoverForeground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Rs.TitleBar.ClosePressedBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Rs.TitleBar.CloseHoverForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource Rs.Surface}"
            BorderBrush="{DynamicResource Rs.Border}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" LastChildFill="True">
                <Button x:Name="RemoveButton"
                        DockPanel.Dock="Right"
                        Padding="0"
                        Margin="-4,-8,-8,0"
                        VerticalAlignment="Top"
                        Style="{StaticResource Rs.Profile.RemoveRound}"
                        Content="&#x00D7;"
                        Click="Remove_OnClick"/>
                <TextBlock x:Name="HeaderTitle"
                           FontWeight="SemiBold"
                           FontSize="15"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                <Label Content="{DynamicResource Loc_MainWindow_LabelName}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource Rs.TextBox.ProfileName}"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="{DynamicResource Loc_MainWindow_LabelWidth}"/>
                        <TextBox x:Name="WBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="{DynamicResource Loc_MainWindow_LabelHeight}"/>
                        <TextBox x:Name="HBox"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="{DynamicResource Loc_MainWindow_LabelHz}"/>
                        <TextBox x:Name="HzBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="{DynamicResource Loc_MainWindow_LabelBpp}"/>
                        <TextBox x:Name="BppBox"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource Rs.Button}"
                            MinWidth="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            ToolTip="{DynamicResource Loc_MainWindow_TooltipGetFromWindows}"
                            Click="GetFromWindows_OnClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE896;"/>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{DynamicResource Loc_MainWindow_ButtonGet}"
                                       Foreground="{DynamicResource Rs.Text.Primary}"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Style="{StaticResource Rs.Button.Accent}"
                            MinWidth="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            ToolTip="{DynamicResource Loc_MainWindow_TooltipApplyProfile}"
                            Click="Apply_OnClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE73E;"/>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{DynamicResource Loc_MainWindow_ButtonApply}"
                                       Foreground="{DynamicResource Rs.Accent}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
